# Firefox Starting
DestroyMenu MenuFirefox
AddToMenu MenuFirefox "Firefox" Title
+ "bank" Exec exec /usr/bin/firefox --new-instance -P bank
+ "google" Exec exec /usr/bin/firefox --new-instance -P google
+ "amazon" Exec exec /usr/bin/firefox --new-instance -P amazon
+ "other logins" Exec exec /usr/bin/firefox --new-instance -P otherlogins
+ "nomem" Exec exec /usr/local/bin/start_firefox_nomem nomem
+ "no mem with mem" Exec exec /usr/bin/firefox --new-instance -P nomem
+ "short term nomem" Exec exec /usr/local/bin/start_firefox_nomem stnomem
+ "short term nomem with mem" Exec exec /usr/bin/firefox --new-instance -P stnomem
+ "facebookhotmail" Exec exec /usr/bin/firefox --new-instance -P facebookhotmail
+ "facebookgmail" Exec exec /usr/bin/firefox --new-instance -P facebookgmail
+ "mail-mil" Exec exec /usr/bin/firefox --new-instance -P mail-mil
+ "herb" Exec exec /usr/bin/firefox --new-instance -P herb
+ "profile" Exec exec /usr/bin/firefox -ProfileManager

