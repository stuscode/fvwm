#Usage: LaunchFF browsertype instancename [keep|erase] 
#keep or erase specifies the profile to be kept or renewed
DestroyFunc LaunchFF
AddToFunc LaunchFF
+ I Echo LaunchFF $0 $1 $2
#save the name of the currently launching browser to tie to the window
+ I InfoStoreAdd browserlaunch $1 
+ I InfoStoreAdd start_erase $2
#launch.  The new window event will catch it and save the name
+ I Test (EnvMatch infostore.start_erase erase) Exec exec /usr/local/bin/start_browser -r $0 ~/ssd/browserdirs/$0 $1
+ I Test (EnvMatch infostore.start_erase keep) Exec exec /usr/local/bin/start_browser $0 ~/ssd/browserdirs/$0 $1
+ I InfoStoreRemove start_erase

