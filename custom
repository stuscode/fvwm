#$[desk.n]

Key Right A CM GotoDesk 1 0 3
Key Left  A CM GotoDesk -1 0 3
Key Down A CM GotoRight
Key Up   A CM GotoLeft

DestroyFunc GotoLeft
AddToFunc GotoLeft
+ I PipeRead '\
   maxpagex=1;\
   maxpagey=1;\
   if [ $[page.nx] -eq 0 ]; then\
      destx=$((maxpagex));\
      if [ $[page.ny] -eq 0 ]; then\
         desty=$((maxpagey));\
      else\
         desty=$(($[page.ny]-1));\
      fi;\
   else\
      destx=$(($[page.nx]-1));\
      desty=$(($[page.ny]));\
   fi;\
   echo GotoDeskAndPage $[desk.n] $((destx)) $((desty))'

DestroyFunc GotoRight
AddToFunc GotoRight
+ I PipeRead '\
   maxpagex=1;\
   maxpagey=1;\
   if [ $[page.nx] -eq $((maxpagex)) ]; then\
      destx=0;\
      if [ $[page.ny] -eq $((maxpagey)) ]; then\
         desty=0;\
      else\
         desty=$(($[page.ny]+1));\
      fi;\
   else\
      destx=$(($[page.nx]+1));\
      desty=$(($[page.ny]));\
   fi;\
   echo GotoDeskAndPage $[desk.n] $((destx)) $((desty))'




